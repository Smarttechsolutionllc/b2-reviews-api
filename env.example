# ---- Core ----
# Railway provides DATABASE_URL automatically when you add a PostgreSQL plugin.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Long random string you keep secret - protects the /admin moderation page.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Your live site origin(s), comma-separated. Use your real domain in production.
# During testing you can use *  (but lock it down before launch).
ALLOWED_ORIGINS=https://your-github-pages-domain.com

# ---- Shopify verified-purchase check (server-side only) ----
SHOPIFY_STORE_DOMAIN=b-squared-apparel-2.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_your_admin_api_token_with_read_orders
SHOPIFY_API_VERSION=2026-04
# true = only verified buyers can post; false = anyone can post, buyers get a badge
REQUIRE_VERIFIED=true

# ---- Photos (Cloudflare R2, S3-compatible) ----
MAX_PHOTOS=3
MAX_PHOTO_MB=8
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=b2-reviews
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
# Public URL base for the bucket (R2 public bucket URL or custom domain)
R2_PUBLIC_BASE=https://pub-xxxx.r2.dev
